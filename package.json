{
  "name": "marktext-for-android",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run src",
    "test:e2e": "playwright test",
    "typecheck": "vue-tsc -b",
    "lint": "eslint . --max-warnings 0",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "android:sync": "pnpm build && cap sync android",
    "android:open": "cap open android",
    "logs:android": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/capture-android-logs.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@muyajs/core": "^0.2.0",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
